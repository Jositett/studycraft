# StudyCraft — environment configuration
# Copy this to .env and fill in your values

# Required — get a free key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative key name (either works)
# STUDYCRAFT_API_KEY=your_openrouter_api_key_here

# Optional — for `studycraft gist` command
# Create at https://github.com/settings/tokens (gist scope)
# GITHUB_TOKEN=your_github_token_here

# Optional — HuggingFace token for faster model downloads (RAG embeddings)
# Get one at https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token_here
